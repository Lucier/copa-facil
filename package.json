{
  "name": "copa-facil",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm --filter '*' build",
    "lint": "pnpm --filter '*' lint",
    "test": "pnpm --filter '*' test",
    "test:unit": "pnpm --filter backend test:unit && pnpm --filter frontend test:unit",
    "test:integration": "pnpm --filter backend test:integration",
    "test:e2e": "pnpm --filter frontend test:e2e",
    "test:coverage": "pnpm --filter backend test:coverage && pnpm --filter frontend test:coverage",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
