# ─── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://copafacil:copafacil@localhost:5433/copafacil

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-string-min
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-random-32-char-string
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Webhooks ──────────────────────────────────────────────────
MP_WEBHOOK_SECRET=change-me-to-your-mercadopago-webhook-secret

# ─── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ─── MinIO / Object Storage ─────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_ASSETS=copa-facil-assets
MINIO_BUCKET_DOCS=copa-facil-documents
# URL pública usada para compor os links retornados pela API.
# Em produção, aponte para o domínio/proxy que expõe o MinIO.
MINIO_PUBLIC_URL=http://localhost:9000
