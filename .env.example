# ─── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://copafacil:copafacil@localhost:5433/copafacil

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────────
