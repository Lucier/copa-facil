# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local — ele está no .gitignore.

# URL da API backend (sem barra final)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# URL interna usada por Server Components e Route Handlers (sem barra final)
BACKEND_URL=http://localhost:3001/api/v1

# Segredo JWT — deve ser idêntico ao JWT_SECRET do backend
# Gerado com: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_COPY_FROM_BACKEND

# Chave de API do portal público para cada tenant (registrada no banco via admin)
# Formato: cfp_<slug>_<random hex 48 chars>
# Gerada com: openssl rand -hex 24 | xargs -I{} echo "cfp_demo_{}"
PORTAL_API_KEY_DEMO=CHANGE_ME_REGISTER_IN_DATABASE
